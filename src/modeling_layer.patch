+    sym.module = "ld";
+    sym.mode = "LD";
+    sym.lvalue = true;
+    sym.static_lifetime = true;
+    sym.file_local = false;
+    sym.is_extern = false;
+    sym.set_type(t);
+    sym.set_value(t.id() == "bool" ? static_cast<exprt>(false_exprt())
